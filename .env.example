# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: Supabase Dashboard > Project Settings > API

# Used by the React frontend (safe to expose — read-only anon key)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Used ONLY by import scripts (never expose this in the browser bundle)
# Get from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
